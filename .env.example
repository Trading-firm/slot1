SL_PCT_INDICES=0.01

# TP is dynamic (0.5% - 2.0%)
TP_MIN_PCT=0.003
TP_MAX_PCT=0.01

# Asset-Specific TP Min
TP_MIN_PCT_FOREX=0.002
TP_MIN_PCT_INDICES=0.004
ATR_MULTIPLIER_TP=1.0

# Legacy Settings (for strategies not yet updated)
