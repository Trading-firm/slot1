# ─── MT5 CONNECTION ───────────────────────────────────────
MT5_LOGIN=your_deriv_account_number
MT5_PASSWORD=your_deriv_password
MT5_SERVER=Deriv-Demo

# ─── MONGODB ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=unified_bot

# ─── RISK MANAGEMENT ─────────────────────────────────────
RISK_PER_TRADE=0.01
MAX_OPEN_TRADES=4
MAX_DAILY_LOSS=0.05
MIN_LOT_SIZE=0.01
MAX_LOT_SIZE=1.0
TP_BIAS=1.2

# ─── SCHEDULER ───────────────────────────────────────────
CHECK_INTERVAL_SECONDS=60

# ─── LOGGING ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/unified_bot.log
